{
	"name": "webhook-manager",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"typecheck": "tsc --noEmit",
		"preview": "pnpm run build && wrangler dev --test-scheduled",
		"deploy": "pnpm run build && wrangler deploy",
		"db:migrate:local": "wrangler d1 migrations apply webhook-manager --local",
		"db:migrate:remote": "wrangler d1 migrations apply webhook-manager --remote",
		"db:execute:local": "wrangler d1 execute webhook-manager --local --command",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"fast-xml-parser": "^5.8.0",
		"hono": "^4.12.23",
		"theme-change": "^2.5.0"
	},
	"devDependencies": {
		"@hono/vite-build": "^1.2.0",
		"@hono/vite-dev-server": "^0.25.2",
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3",
		"vite": "^6.3.5",
		"wrangler": "^4.94.0"
	}
}
